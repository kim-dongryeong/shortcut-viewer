{
  // ───────── [상수층] 모든 프로젝트 공통 — 새 프로젝트에 그대로 복붙 ─────────
  "window.title": "${rootName} ⌨️ ${activeEditorShort}", // 타이틀바에 프로젝트명 + 현재 파일
  // "workbench.colorTheme": "Ayu Mojave", // 키가 미리 있어야 cmd+K cmd+T가 이 workspace에만 기록(아래 섹션)
  "workbench.tree.indent": 16,
  "editor.fontSize": 18,
  "terminal.integrated.fontSize": 18,
  "chat.fontSize": 20,
  "chat.editor.fontSize": 12,

  // ───────── [변수층] 프로젝트별 색 ─────────
  "workbench.colorCustomizations": {
    // 🅐: Project의 identity
    // 🅑: Workspace color theme에 의한 배경색(dart/light)에 대비해서 잘 보이는 색. "선택 표시 색"
    // 🅒: 🅑만큼은 아니지만 배경색에 대비가 약간 필요함. 웬만하면 🅐, 아니면 🅑, 아니면 새로운 색
    // 🅓: 🅐와 비슷하지만 희미한 색
    // 🅔: 회색빛 무채색
    // 🟥 Peacock이 active면 reopen마다 삭제 → disable해야 유지

    // 🟩 진짜 외래(ColorSettings 비멤버) — active여도 Peacock이 안 건드림
    // "tab.inactiveBackground": "#3c3c45", // 중립(고정)
    "tab.activeBackground": "#5e5d68",   // 중립(고정)
    "tab.border": "#2563eb",             // 중립(고정)  탭의 좌우 세로 경계선
    "window.activeBorder": "#2563eb",    // 🅐  창 전체 테두리
    "window.inactiveBorder": "#2563eb",  // 🅐
    // --- Layout & Panels --- (단순히 채워넣기)
    "titleBar.border": "#2563eb",        // 🅐  Border at the bottom of the top title bar
    "activityBar.border": "#2563eb",     // 🅐  activity bar(최왼쪽에 아이콘들)와 왼쪽 사이드바(Explorer) 사이 경계 (안중요)
    "statusBar.border": "#2563eb",       // 🅐🟥  맨아래 (statusBar지만 affectStatusAndTitleBorders off → 삭제 대상) (Peacock이 삭제)
    // 세로 선들
    "sideBar.border": "#2563eb",         // 🅒🟥  좌우사이드바와 에디터 사이 경계(cmd+(opt)+B)
    "panel.border": "#2563eb",           // 🅒🟥  에디터와 하단 패널 사이 경계(control+`)
    "terminal.border": "#2563eb",        // 🅒 Borders separating split terminal instances
    "editorGroup.border": "#7dd3fc",     // 🅑🟥  split 창 가운데 경계(cmd+\)
    "diffEditor.border": "#a5b0c9",      // 🅔  compare view 경계선

    // 선택
    "tab.activeBorderTop": "#7dd3fc",           // 🅑 선택된 탭의 윗경계
    "tab.activeBorder": "#7dd3fc",              // 🅑🟥  선택된 탭의 아래경계
    "tab.unfocusedActiveBorderTop": "#7dd3fc",  // 🅑 선택된 탭의 윗경계 (다른 editor group)
    "tab.unfocusedActiveBorder": "#7dd3fc",     // 🅑 선택된 탭의 아래경계 (다른 editor group)
    "focusBorder": "#7dd3fc",                   // 🅑 Explorer 파일 선택 테두리
    // "panelTitle.activeBorder": "#7dd3fc",      // 🅑 터미널 등의 탭 아래 선택 표시선 (기본 테마가 부족할 때만)
    
    // // --- Inputs, Buttons, & Dropdowns ---
    "inputOption.activeBorder": "#7dd3fc", // 🅑 Border around active options in input fields (like Regex icon)
    // "button.border": "#ff0000",           // 세팅에서 Border around primary buttons (일반 버튼)
    // "checkbox.border": "#ff0000",         // 세팅에서 Border around toggle checkboxes
    
    // // --- In-Editor Code Highlights --- (커서 행, 문자열 선택, 찾기, 괄호쌍 등) (기본 테마가 부족할 때)
    "editor.lineHighlightBorder": "#7dd3fc",       // 🅓vs🅑 커서 행
    "editor.selectionHighlightBorder": "#7dd3fc",  // 🅑 cmd+D
    "editor.findMatchBorder": "#7dd3fc",           // 🅑 cmd+F
    "editorBracketMatch.border": "#7dd3fc",        // 🅑 Border around the matching bracket pairs {} [] ()
    // "editor.findMatchHighlightBorder": "#0e275c", // Border around all other search result highlights
    
    // --- Global & Window Borders --- 보조 경계선 🅐와 비슷하지만 희미한 색 (기본 테마가 부족할 때)
    "contrastBorder": "#0e275c",               // 🅓 Border around all major UI elements (High Contrast mode)
    "editorGroupHeader.tabsBorder": "#0e275c", // 🅓 Thin line below tabs
    "editorOverviewRuler.border": "#0e275c",   // 🅓 스크롤바 옆에 경계선
    
    // // --- Code Editor UI Elements --- (회색빛 무채색) (기본 테마가 부족할 때)
    "editorWidget.border": "#a5b0c9",         // 🅔 에이전트 채팅박스 경계선
    "editorHoverWidget.border": "#a5b0c9",    // 🅔 팝업 툴팁 테두리
    "input.border": "#a5b0c9",                // 🅔 Border around all text input boxes (e.g., search, settings)
    "sideBarSectionHeader.border": "#a5b0c9", // 🅔 Explorer, Search, Source Control 등 사이드바의 섹션 헤더 경계선, 에이전트 대화 세로 선

    // 기타
    // "tab.activeForeground": "#7dd3fc",  // 선택되지 않은 탭의 글자와 변경 및 단기 아이콘 (안중요)
    // "editorGutter.background": "#ff0000",     // 에디터 행 번호 영역 배경색
    // "editorLineNumber.foreground": "#ff0000", // 에디터 행 번호 글자색
    
    // 몰라
    "notificationToast.border": "#FF0000",
    "notificationCenter.border": "#FF0000",
    "notifications.border": "#00FF00",
    // Editor pane and split-view thin borders
    "editorPane.background": "#ff0000",      // ?? Background to help control visual bleed
    "scm.providerBorder": "#ff0000",           // ?? Borders separating mult (터미널?)
    "dropdown.border": "#ff0000",          // ?? Border around select dropdown menus

    // 🟦 소유 키 — Peacock이 peacock.color(=🅐)로 생성 (disable로 freeze)
    "activityBar.activeBackground": "#5484ef",
    "activityBar.background": "#5484ef",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#fac5d5",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#5484ef",                // Color when clicking/dragging to resize
    "statusBar.background": "#2563eb",            // 🅐
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#5484ef",
    "statusBarItem.remoteBackground": "#2563eb",  // 🅐
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#2563eb",       // 🅐
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#2563eb99",   // 🅐
    "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#2563eb", // 🅐 — Peacock으로 이 한 줄을 깔고 disable
}