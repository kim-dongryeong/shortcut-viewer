{
  "_readme": "SV Hotkeys 설정. 이 파일을 ~/.config/shortcut-viewer/hotkeys.json 으로 복사하면 데몬이 읽습니다(뷰어에서 '글로벌 핫키' 내보내기로 자동 생성 가능). mods=[cmd,opt,ctrl,shift], key=뷰어와 같은 이름(A~Z,0~9,Space,Return,F1…,Left…). anyCombo=true면 다른 앱도 잡는 조합까지 가로챔(Accessibility 필요). 초보자는 ⌥ 또는 ⌃⌥ 레이어를 추천 — 시스템·앱과 안 겹칩니다.",
  "_action_types": "open_app(앱이름/경로/번들id) · open_url · open_folder(폴더경로) · open_file · run_shell(zsh 명령) · applescript · paste_text(클립보드+⌘V, Accessibility 필요) · show_viewer(Shortcut Viewer 열기) · mouse_save(value=슬롯, 현재 마우스 위치 저장) · mouse_goto(슬롯 위치로 커서 이동) · mouse_click(슬롯으로 이동→클릭→커서 복귀, Accessibility 필요) · preset_toggle(value=프리셋id, 켬/끔) · preset_activate(value=프리셋id, 그 프리셋만 켜고 나머지 서브프리셋은 끔 — 라디오) · insert_datetime(value=DateFormatter 패턴, 예 yyyy-MM-dd — strftime 아님)",
  "_presets": "v2: BTT 마스터+서브프리셋 모델. master는 always_on(항상 발화), 나머지는 enabled로 켬/끔. 항상 쓰고 싶은 키는 master에 두세요 — preset_activate는 서브프리셋을 라디오처럼 하나만 남기고 나머지를 끕니다.",
  "version": 2,
  "presets": {
    "master":   {"title": "마스터 — 항상 켜짐 (프리셋 전환 키)", "always_on": true},
    "base":     {"title": "기본 (앱·폴더·URL)", "enabled": true},
    "datetime": {"title": "날짜·시간 입력", "enabled": true},
    "mousebm":  {"title": "마우스 북마크", "enabled": false}
  },
  "hotkeys": [
    {"id":"viewer",   "preset":"master", "title":"내 단축키 전체 보기 (Shortcut Viewer)", "mods":["opt"],        "key":"Space", "action":{"type":"show_viewer","value":""}},
    {"id":"preset_base",     "preset":"master", "title":"프리셋: 기본만 켜기",       "mods":["ctrl","opt"], "key":"8", "action":{"type":"preset_activate","value":"base"}},
    {"id":"preset_datetime", "preset":"master", "title":"프리셋: 날짜·시간 켬/끔",   "mods":["ctrl","opt"], "key":"9", "action":{"type":"preset_toggle","value":"datetime"}},
    {"id":"preset_mousebm",  "preset":"master", "title":"프리셋: 마우스 북마크 켬/끔","mods":["ctrl","opt"], "key":"0", "action":{"type":"preset_toggle","value":"mousebm"}},

    {"id":"finder",   "preset":"base", "title":"Finder(파인더) 열기",                   "mods":["opt"],        "key":"F",     "action":{"type":"open_app","value":"Finder"}},
    {"id":"calc",     "preset":"base", "title":"계산기 열기",                            "mods":["opt"],        "key":"C",     "action":{"type":"open_app","value":"Calculator"}},
    {"id":"term",     "preset":"base", "title":"터미널 열기",                            "mods":["ctrl","opt"], "key":"T",     "action":{"type":"open_app","value":"Terminal"}},
    {"id":"home",     "preset":"base", "title":"홈 폴더 열기",                           "mods":["opt"],        "key":"H",     "action":{"type":"open_folder","value":"~"}},
    {"id":"downloads","preset":"base", "title":"다운로드 폴더 열기",                     "mods":["opt"],        "key":"D",     "action":{"type":"open_folder","value":"~/Downloads"}},
    {"id":"google",   "preset":"base", "title":"Google 열기",                           "mods":["opt"],        "key":"G",     "action":{"type":"open_url","value":"https://www.google.com"}},
    {"id":"gpt",      "preset":"base", "title":"ChatGPT 열기",                          "mods":["opt"],        "key":"Return","action":{"type":"open_url","value":"https://chatgpt.com"}},
    {"id":"lock",     "preset":"base", "title":"화면 잠그고 절전",                       "mods":["ctrl","opt"], "key":"L",     "action":{"type":"run_shell","value":"pmset displaysleepnow"}},
    {"id":"shot",     "preset":"base", "title":"영역 스크린샷 (클립보드로)",             "mods":["ctrl","opt"], "key":"S",     "action":{"type":"run_shell","value":"screencapture -i -c"}},
    {"id":"email",    "preset":"base", "title":"내 이메일 주소 붙여넣기",                "mods":["opt"],        "key":"E",     "action":{"type":"paste_text","value":"me@example.com"}},
    {"id":"dark",     "preset":"base", "title":"다크 모드 켜기/끄기",                    "mods":["ctrl","opt"], "key":"M",     "enabled":false, "action":{"type":"applescript","value":"tell application \"System Events\" to tell appearance preferences to set dark mode to not dark mode"}},
    {"id":"newnote",  "preset":"base", "title":"새 메모",                               "mods":["opt"],        "key":"N",     "action":{"type":"applescript","value":"tell application \"Notes\" to make new note"}},
    {"id":"emptytrash","preset":"base","title":"휴지통 비우기 (안전상 기본 꺼짐)",       "mods":["ctrl","opt"], "key":"Delete","enabled":false, "action":{"type":"applescript","value":"tell application \"Finder\" to empty trash"}},
    {"id":"spotify",  "preset":"base", "title":"Spotify 재생/일시정지 (anyCombo 예시)",  "mods":["ctrl","opt"], "key":"P",     "anyCombo":false, "action":{"type":"applescript","value":"tell application \"Spotify\" to playpause"}},

    {"id":"figma_only","preset":"base","title":"고급① Figma에서만 ⌥R",     "mods":["opt"], "key":"R", "app":"Figma", "enabled":false, "action":{"type":"run_shell","value":"echo figma-rename"}},
    {"id":"ropt_j",    "preset":"base","title":"오른쪽 ⌥+J (L/R 구분)",      "mods":["ropt"], "key":"J", "enabled":false, "action":{"type":"open_app","value":"Finder"}},
    {"id":"lcmd2",     "preset":"base","title":"왼쪽 ⌘ 더블탭 → 뷰어",       "trigger":{"kind":"double","mod":"cmd","side":"left"}, "enabled":false, "action":{"type":"show_viewer","value":""}},
    {"id":"shift_hold","preset":"base","title":"⇧ 길게 누름 → 영역 스크린샷", "trigger":{"kind":"hold","mod":"shift","ms":450}, "enabled":false, "action":{"type":"run_shell","value":"screencapture -i -c"}},
    {"id":"leader_c",  "preset":"base","title":"리더: ⌥Space → C → 계산기",  "sequence":[{"mods":["opt"],"key":"Space"},{"mods":[],"key":"C"}], "enabled":false, "action":{"type":"open_app","value":"Calculator"}},

    {"id":"dt_d",    "preset":"datetime", "title":"날짜(숫자만) → yyMMdd",        "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"D"}], "action":{"type":"insert_datetime","value":"yyMMdd"}},
    {"id":"dt_iso",  "preset":"datetime", "title":"날짜(ISO) → yyyy-MM-dd",       "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"I"}], "action":{"type":"insert_datetime","value":"yyyy-MM-dd"}},
    {"id":"dt_dot",  "preset":"datetime", "title":"날짜(점) → yyyy.MM.dd",        "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"."}], "action":{"type":"insert_datetime","value":"yyyy.MM.dd"}},
    {"id":"dt_kr",   "preset":"datetime", "title":"날짜(한글) → yyyy년 M월 d일",   "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"K"}], "action":{"type":"insert_datetime","value":"yyyy년 M월 d일"}},
    {"id":"dt_t",    "preset":"datetime", "title":"시간 → HH:mm",                 "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"T"}], "action":{"type":"insert_datetime","value":"HH:mm"}},
    {"id":"dt_s",    "preset":"datetime", "title":"시간(초) → HH:mm:ss",          "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"S"}], "action":{"type":"insert_datetime","value":"HH:mm:ss"}},
    {"id":"dt_full", "preset":"datetime", "title":"날짜+시간 → yyyy-MM-dd HH:mm", "sequence":[{"mods":["ctrl","opt"],"key":"D"},{"mods":[],"key":"F"}], "action":{"type":"insert_datetime","value":"yyyy-MM-dd HH:mm"}},

    {"id":"mb1_save", "preset":"mousebm", "title":"고급② 마우스 북마크 1 저장 (⌃⌥1)",       "mods":["ctrl","opt"], "key":"1", "action":{"type":"mouse_save","value":"1"}},
    {"id":"mb1_use",  "preset":"mousebm", "title":"고급② 마우스 북마크 1 클릭+복귀 (⌥1)",     "mods":["opt"], "key":"1", "action":{"type":"mouse_click","value":"1"}},
    {"id":"mb1_goto", "preset":"mousebm", "title":"고급② 마우스 북마크 1로 커서만 이동 (⌥⇧1)", "mods":["opt","shift"], "key":"1", "action":{"type":"mouse_goto","value":"1"}}
  ]
}
