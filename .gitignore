vscode_default_keybindings.json
codex_keybindings.json
raycast_manual.json
manual_globals.json
manual_gestures.json
win/manual_globals_win.json
annotations.json

# ── Compiled binary (rebuild from axmenudump.swift) ───────────────────
axmenudump
*.o

# ── SV Hotkeys daemon build artifacts + generated per-machine config ───
hotkeys/svhotkeys
hotkeys/SV Hotkeys.app/
SV Hotkeys.app/
*.dmg
# generated by gen_hotkeys.py (contain your home path / actual hotkeys — PII)
hotkeys.json
karabiner-sv.json
skhdrc.sv
hammerspoon-sv.lua

# ── Raw vendor keymap snapshots (Adobe .kys/.htm 등) — 재파싱용 로컬 보관.
#    저작물이라 커밋 금지: 파생된 defaults/ 팩만 추적한다.
_sources/

# ── 배포판 빌드 산출물(packaging/*/build_*.sh|.spec가 만듦) — 스크립트만 추적, 결과물은 재빌드 ──
packaging/mac/dist/
packaging/win/build/
packaging/win/dist/
*.exe

# ── Python / macOS cruft ──────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.vscode/*
!.vscode/settings.json
.vscode
