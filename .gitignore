# ── Generated output (rebuilt by build.py / render.py) ────────────────
viewer.html
shortcuts.json
btt_export.json

# ── Personal data — YOUR shortcuts. Never commit. ─────────────────────
vscode_default_keybindings.json
codex_keybindings.json
raycast_manual.json
manual_globals.json
manual_gestures.json
annotations.json

# ── Compiled binary (rebuild from axmenudump.swift) ───────────────────
axmenudump
*.o

# ── Raw vendor keymap snapshots (Adobe .kys/.htm 등) — 재파싱용 로컬 보관.
#    저작물이라 커밋 금지: 파생된 defaults/ 팩만 추적한다.
_sources/

# ── Python / macOS cruft ──────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
.vscode/*
!.vscode/settings.json
